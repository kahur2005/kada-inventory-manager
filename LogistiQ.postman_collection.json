            "description": "warehouse_admin only. warehouse inferred from req.user.warehouse. Validates & decrements warehouse stock per line; rejects with per-item errors if insufficient. Allocates sequential code BX-000N + uuid qrToken. 201 { box, qrDataUrl }. 400 missing fields / bad ObjectIds / not linked to a warehouse / insufficient stock (errors: [...]).",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destinationStore\": \"{{storeId}}\",\n  \"items\": [\n    {\n      \"item\": \"{{itemId}}\",\n      \"qty\": 10\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) { pm.environment.set('boxId', pm.response.json().box._id); pm.environment.set('boxToken', pm.response.json().box.qrToken); pm.environment.set('boxCode', pm.response.json().box.code); }"
                ]
              }
            }
          ]
        },
        {
          "name": "List Boxes",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/boxes?status=&search=&page=1&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "boxes"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "page",
                  "value": "1",
                  "disabled": false
                },
                {
                  "key": "limit",
                  "value": "10",
                  "disabled": false
                }
              ]
            },
            "description": "superadmin, warehouse_admin, driver, store_admin (role-scoped). status filter: PACKED|ASSIGNED|IN_TRANSIT|DELIVERED. search matches box code. 200 { boxes, total, page, limit }. 401."
          },
          "response": []
        },
        {
          "name": "Regenerate Box QR",
